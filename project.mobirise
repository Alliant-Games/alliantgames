          "_name": "slider01",
          "_sourceTheme": "rangem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider1 mbr-embla\" group=\"Gallery &amp; Slider\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"embla\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\" checked=\"\">\n\t\t<input inline=\"\" type=\"range\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n\t\t<input inline=\"\" type=\"range\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\">\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\" checked=\"\">\n\t\t<input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n\t\t<header>Carousel</header>\n\t\t<input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\">\n\t\t<input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"5\" step=\"1\" condition=\"autoplay\">\n\t\t<input type=\"checkbox\" title=\"Loop\" name=\"loop\" checked=\"\">\n\t\t<input type=\"checkbox\" title=\"Draggable\" name=\"draggable\" checked=\"\">\n\t\t<input type=\"checkbox\" title=\"Arrows\" name=\"arrows\" checked=\"\">\n\t\t<header>Card</header>\n\t\t<input type=\"range\" name=\"gap\" title=\"Gap\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n\t\t<input type=\"range\" name=\"carouselHeight\" title=\"Height\" min=\"1\" max=\"8\" step=\"1\" value=\"4\">\n\t\t<input type=\"range\" name=\"cardWidth\" title=\"Width\" min=\"1\" max=\"12\" step=\"1\" value=\"6\">\n\t\t<input type=\"checkbox\" name=\"cardBorder\" title=\"Border\" checked=\"\">\n\t\t<input type=\"color\" name=\"borderColor\" title=\"Color\" value=\"#19c2ec\" condition=\"cardBorder\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax=\"\">\n\t\t\t<input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/rangem5/components/_images/background1.jpg\" parallax=\"\">\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#260a30\" selected=\"\">\n\t\t</fieldset>\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked=\"\">\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n\t\t<input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n\t</mbr-parameters>\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n\t</div>\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row mb-5 justify-content-center\" mbr-if=\"showMainTitle || showMainSubtitle\">\n\t\t\t<div class=\"col-12 content-head\">\n\t\t\t\t<div class=\"mb-4 text-center\">\n\n\t\t\t\t\t<h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\"><b>2022</b></h3>\n\t\t\t\t</div>\n\n\n\t\t\t\t<h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n\t\t\t\t\tCarousel with Multiple Items\n\t\t\t\t</h5>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"row\">\n\t\t\t<div class=\"col-12\">\n\t\t\t\t<div class=\"embla position-relative\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n\t\t\t\t\t<div class=\"embla__viewport\">\n\t\t\t\t\t\t<div class=\"embla__container\">\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t<div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n\t\t\t\t\t\t\t\t<div class=\"slide-content\">\n\t\t\t\t\t\t\t\t\t<div class=\"item-img\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"item-wrapper\">\n\t\t\t\t\t\t\t\t\t\t\t<img class=\"card-img-bg w-100 h-100\" src=\"@PROJECT_PATH@/assets/images/season201320map-1200x1200.webp\" alt=\"Season 8\" title=\"\" data-slide-to=\"13\" data-bs-slide-to=\"13\">\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"card-box row\">\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"col pe-0\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<h3 class=\"card-title card-title-1 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title-1\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<b>Season 13</b></h3>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text\">Season 1 Anniversary Map (RobJ)</p>\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"col-auto icon-wrapper d-flex align-items-center overflow-hidden\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"#\"><span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span></a>\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div><div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n\t\t\t\t\t\t\t\t<div class=\"slide-content\">\n\t\t\t\t\t\t\t\t\t<div class=\"item-img\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"item-wrapper\">\n\t\t\t\t\t\t\t\t\t\t\t<img class=\"card-img-bg w-100 h-100\" src=\"@PROJECT_PATH@/assets/images/season201420map-1200x1200.webp\" alt=\"Season 8\" title=\"\" data-slide-to=\"14\" data-bs-slide-to=\"14\">\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"card-box row\">\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"col pe-0\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<h3 class=\"card-title card-title-1 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title-1\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<b>Season 14</b></h3>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text\">Detroit: Irreparable Damage (Gruber)</p>\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"col-auto icon-wrapper d-flex align-items-center overflow-hidden\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"#\"><span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span></a>\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div><div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n\t\t\t\t\t\t\t\t<div class=\"slide-content\">\n\t\t\t\t\t\t\t\t\t<div class=\"item-img\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"item-wrapper\">\n\t\t\t\t\t\t\t\t\t\t\t<img class=\"card-img-bg w-100 h-100\" src=\"@PROJECT_PATH@/assets/images/season201520map-1200x1200.webp\" alt=\"Season 8\" title=\"\" data-slide-to=\"15\" data-bs-slide-to=\"15\">\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"card-box row\">\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"col pe-0\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<h3 class=\"card-title card-title-1 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title-1\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<b>Season 15</b></h3>\n\t\t\t\t\t\t\t\t\t\t\t\t\t<p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text\">Procedural Map</p>\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"col-auto icon-wrapper d-flex align-items-center overflow-hidden\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"#\"><span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span></a>\n\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\