                  "opacity": "1",
                  "&:hover": {
                    "opacity": "1",
                    "color": "#FFFFFF !important"
                  },
                  "justify-content": "flex-start",
                  "&:hover, &:focus, &:active": {
                    "opacity": "1",
                    "color": "#FFFFFF !important"
                  }
                },
                "width": "100%",
                "text-align": "left",
