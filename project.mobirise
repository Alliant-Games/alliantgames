>\n\t\t\t\t\t\t<span class=\"sr-only visually-hidden visually-hidden\">Next</span>\n\t\t\t\t\t</button>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = \"video\")": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "@media (min-width: 768px)": {
                  "padding": "0"
                }
              }
            },
            ".embla__slide": {
              "display": "flex",
              "justify-content": "center",
              "position": "relative",
              "min-width": "(@cardWidth * 75px)",
              "max-width": "(@cardWidth * 75px)",
              "@media (max-width: 600px)": {
                "min-width": "100%",
                "max-width": "100%",
                "margin-left": "1rem !important",
                "margin-right": "1rem !important"
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex",
              "transition": "all 0.3s ease",
              "opacity": "0 !important",
              "@media (max-width: 767px)": {
                "opacity": "1 !important",
                "margin": "0",
                "transform": "translateX(0)"
              }
            },
            ".embla__button--prev": {
              "transform": "translateX(3rem)"
            },
            ".embla__button--next": {
              "transform": "translateX(-3rem)"
            },
            ".mobi-mbri-arrow-next": {
              "margin-left": "5px"
            },
            ".mobi-mbri-arrow-prev": {
              "margin-right": "5px"
            },
            ".embla__button": {
              "top": "50%",
              "width": "60px",
              "height": "60px",
              "margin-top": "-1.5rem",
              "font-size": "30px",
              "border": "1px solid #fff",
              "border-radius": "50%",
              "position": "absolute",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "& when not (@arrows)": {
                "display": "none"
              },
              "&:disabled": {
                "cursor": "default",
                "display": "none"
              },
              "&.embla__button--prev": {
                "left": "0",
                "margin-left": "2.5rem"
              },
              "&.embla__button--next": {
                "right": "0",
                "margin-right": "2.5rem"
              }
            },
            ".embla": {
              "position": "relative",
              "width": "100%",
              "&:hover": {
                ".embla__button--next, .embla__button--prev": {
                  "transform": "translateX(0)",
                  "opacity": "1 !important"
                }
              },
              ".embla__button--next, .embla__button--prev": {
                "@media (max-width: 767px)": {
                  "opacity": "1 !important",
                  "margin": "0",
                  "transform": "translateX(0)"
                }
              }
            },
            ".embla__viewport": {
              "overflow": "hidden",
              "width": "100%"
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            "& when (@draggable)": {
              ".embla__slide a": {
                "cursor": "grab"
              },
              ".embla__slide a:active": {
                "cursor": "grabbing"
              }
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent"
            },
            ".mbr-section-title": {
              "color": "#8320d2",
              ".mbr-iconfont": {
                "color": "#bff747",
                "transition": "all 300ms ease"
              }
            },
            ".mbr-section-subtitle": {
              "color": "#fdfde1"
            },
            ".mbr-box": {
              "color": "#ffffff"
            },
            ".slide-content": {
              "position": "relative",
              "height": "100%",
              "width": "100%",
              "display": "flex",
              "overflow": "hidden",
              "flex-flow": "column nowrap"
            },
            ".card-title": {
              "width": "100%",
              "margin-bottom": "0",
              "color": "#fffff5",
              "position": "relative",
              "transition": "all 300ms ease"
            },
            ".card-text": {
              "line-height": "1.66",
              "width": "100%",
              "color": "#fdfde1",
              "margin-bottom": "0",
              "position": "relative",
              "overflow": "hidden",
              "display": "-webkit-box",
              "-webkit-box-orient": "vertical",
              "-webkit-line-clamp": "2"
            },
            ".item-img": {
              "object-fit": "cover",
              "overflow": "hidden",
              "transition": "all 300ms ease",
              "& when (@cardBorder)": {
                "background-color": "@borderColor",
                "padding": "0.3rem"
              }
            },
            ".item-wrapper": {
              "position": "relative",
              "overflow": "hidden !important",
              "transition": "all 300ms ease",
              "height": "(@carouselHeight * 100px)",
              ".icon-wrapper": {
                "transition": "all 300ms ease"
              },
              ".card-box": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "padding": "1.5rem 0 1.5rem 1.5rem",
                "z-index": "11",
                ".mbr-iconfont": {
                  "font-size": "2rem",
                  "color": "#ffffff",
                  "transition": "all 300ms ease"
                }
              },
              ".card-text": {
                "font-size": "1.1rem"
              },
              "img": {
                "transition": "all 300ms ease",
                "object-fit": "cover"
              },
              "&::after": {
                "content": "\"\"",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background": "linear-gradient(to bottom, transparent, #000000)",
                "opacity": "0.6",
                "transition": "all 0.3s ease-in-out",
                "pointer-events": "none"
              },
              "&:hover": {
                ".icon-wrapper": {
                  "transform": "translateX(10px)"
                },
                "img": {
                  "transform": "scale3d(1.1, 1.1, 1.1)"
                },
                ".card-title, .mbr-iconfont": {
                  "color": "#bff747"
                }
              }
            },
            ".content-head": {
              "max-width": "856px"
            },
            ".card-title-1": {
              "color": "#fdfde1"
            },
            ".icon-wrapper": {
              "position": "relative",
              "overflow": "hidden"
