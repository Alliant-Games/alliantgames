            },
            ".navbar-nav": {
              ".nav-item": {
                "margin": "0 !important",
                ".nav-link": {
                  "margin": "0 !important",
                  "padding": "10px 0 !important",
                  "transition": "0.3s all",
                  "opacity": "1",
                  "&:hover": {
