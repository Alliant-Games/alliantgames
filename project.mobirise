                "display": "flex",
                "flex-direction": "column",
                "align-items": "stretch",
                "width": "100%",
                "margin-left": "-0.6rem",
                "margin-right": "-0.6rem",
                ".btn": {
                  "flex-grow": "1"
                }
              }
            },
            ".nav-dropdown .link.dropdown-toggle::after, .dropdown-toggle[data-toggle=\"dropdown-submenu\"]::after": {
              "content": "\"+\"",
              "border": "none !important",
              "display": "inline-block",
              "margin-left": ".5rem",
              "margin-top": "0",
              "position": "static",
              "line-height": "1",
              "font-weight": "700",
              "color": "currentColor",
              "transform": "none"
            },
            "@media (max-width: 991px)": {
              ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]::after": {
                "content": "\"+\"",
                "border": "none !important"
              }
            }
          },
          "_cid": "uUaEIHnzfs",
          "_anchor": "amenu2-z",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "_name": "article03",
          "_sourceTheme": "progressm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article03 progressm5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"9\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/progressm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#13161f\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/progressm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#060606\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row items-wrapper\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"content-wrapper\">\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle || showText\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">\n                            ABOUT US</h2>\n                        <div class=\"text-wrapper\">\n                            <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">Alliant Games is a premier gaming community and server provider, dedicated to creating memorable, fun, and reliable experiences for players around the world.\n<br>\n<br>Founded on July 24, 2020, Alliant Games operates as a proud subsidiary of Dusty Hansen Productions LLC. The company is headquartered in the United States at 2501 Chatham Rd STE N, Springfield, Illinois, and is established under the laws of the State of Illinois.\n<br>\n<br>From its inception, Alliant Games has focused on fostering a strong alliance between players, developers, and staff—building a welcoming community where collaboration and enjoyment are at the forefront. The company’s flagship offering is its Rust PVE (Player vs. Environment) server, which launched in January 2021 and quickly grew in popularity during the Rust “OTV craze.” The server stands out with its blend of PVE gameplay, dedicated PVP zones, and unique Purge events at the end of each biweekly wipe.\n<br>\n<br>Alliant Games is known for its innovative features, including custom plugins, skill trees, raidable bases, quality-of-life improvements, and a robust event schedule. Players can participate in a wide range of in-game activities, from massive cargo events and armored train heists to water-based adventures and special seasonal competitions.\n<br>\n<br>The server also offers a tiered VIP system, allowing players to support the community while unlocking exclusive perks and benefits.\n<br>\n<br>Committed to transparency and community involvement, Alliant Games encourages player feedback through Discord, hosts regular events, and maintains a responsive support team. The company also extends its presence to other multiplayer games, including a Path of Exile 2 guild, and continues to explore new ways to deliver engaging content and experiences.\n<br>\n<br>Alliant Games operates under the core values of community, reliability, and innovation. Whether you’re a seasoned gamer or new to the scene, Alliant Games invites you to join its alliance and discover what makes its community unique.\n<br>\n<br>For more information, visit https://alliantgames.com or contact support at support@alliant.gg</p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                Get started now\n                            </a>\n                            <a class=\"btn btn-success\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more info\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/white204-1224x1144.webp\" alt=\"Mobirise\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".items-wrapper": {
              "margin": "0 -32px",
              "justify-content": "center",
              ".card": {
                "padding": "0 32px",
                "justify-content": "center"
              }
            },
            ".title-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "48px"
              },
              ".mbr-section-title": {
                "margin-bottom": "24px"
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "margin-bottom": "24px",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".image-wrapper": {
              "img": {
                "height": "480px",
                "object-fit": "cover",
                "@media (max-width: 992px)": {
                  "height": "350px"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#9aa0a6"
            }
          },
          "_cid": "uU4K17RV8L",
          "_anchor": "article03-a",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = \"video\")": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".item-mb": {
              "margin-bottom": "2rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "0"
              }
            },
            ".item-wrapper": {
              "background": "@cardbg",
              "padding": "2.25rem",
              "@media (min-width: 992px) and (max-width: 1200px)": {
                "padding": "2rem 1.5rem",
                "margin-bottom": "0rem"
              },
              "@media (max-width: 767px)": {
                "padding": "2rem 1.5rem",
                "margin-bottom": "1rem"
              }
            },
            ".mbr-iconfont": {
              "display": "inline-flex",
              "font-size": "3rem",
              "color": "@iconColor",
              "margin-bottom": "1rem",
              "width": "80px",
              "justify-content": "center",
              "align-items": "center",
              "background": "@iconbg",
              "height": "80px",
              "border-radius": "50%"
            },
            ".mbr-section-title": {
              "color": "#d70081"
            },
            ".mbr-section-subtitle": {
              "color": "#232323"
            },
            ".card-box": {
              "display": "flex",
              "flex-direction": "column",
              "height": "100%",
              ".item-footer": {
                "margin-top": "auto"
              }
            },
            ".content-head": {
              "max-width": "800px"
            }
          },
          "_name": "features022",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features22\" group=\"Features\" plugins=\"Masonry\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\" checked>\n    <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n    <header>Card</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n    <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n    <input type=\"checkbox\" title=\"Icons\" name=\"showIcon\" checked>\n    <input type=\"checkbox\" name=\"showButtons\" title=\"Buttons\">\n    <input type=\"color\" title=\"Icon Color\" name=\"iconColor\" value=\"#d70081\" selected condition=\"showIcon\">\n    <input type=\"color\" title=\"Icon BG\" name=\"iconbg\" value=\"#ffd7ef\" selected condition=\"showIcon\">\n    <select title=\"Columns\" name=\"columns\">\n      <option value=\"12\">1</option>\n      <option value=\"6\">2</option>\n      <option value=\"4\" selected>3</option>\n      <option value=\"3\">4</option>\n    </select>\n    <input type=\"color\" title=\"BG\" name=\"cardbg\" value=\"#ffffff\" selected>\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n      <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n      <input type=\"color\" title=\"Color\" value=\"#13161f\" selected>\n      <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n    </fieldset>\n    <header condition=\"bg.type === 'video'\">Fallback Image</header>\n    <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n  </mbr-parameters>\n\n  <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row mb-5 justify-content-center\" mbr-if=\"showMainTitle || showMainSubtitle\">\n      <div class=\"col-12 content-head\">\n        <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\">\n          <b>Why play at Alliant Games?</b></h3>\n        <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent\n          vitae erat. Integer aliquam, lorem vitae dapibus sollicitudin, nibh\n          nisl egestas enim, ut dapibus odio augue tempus venenatis mi semper.\n        </h5>\n      </div>\n    </div>\n    <div class=\"row mbr-masonry\" data-masonry=\"{&quot;percentPosition&quot;: true }\">\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-help mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Exceptional Staff &amp; Community Support</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n              Our dedicated and experienced staff go above and beyond to ensure a memorable gaming experience. We also provide unparalleled member support with quick response times and a proactive approach to resolving issues.\n            </p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-idea mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Player-Centered Philosophy</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n              Member feedback is at the core of our development. We actively listen, prioritize suggestions, and foster a collaborative environment where players' voices truly matter.\n            </p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-setting mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Commitment to Innovation</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">We embrace new technologies like AI, experiment with bold ideas, and continuously evolve by adding, refining, or removing features to keep the experience fresh and engaging.<br></p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-extension mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Unique Gaming Experience</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Hybrid Playstyles: We offer a one-of-a-kind combination of roleplay (RP), player-versus-environment (PVE), and player-versus-player (PVP) gameplay.\n<br>\n<br>Custom &amp; Procedural Maps: Players can enjoy a versatile mix of procedural and custom-designed maps for a dynamic experience.\n<br>\n<br>Exclusive Features: From our unique user interface (UI) to quality-of-life (QOL) enhancements and engaging events, we provide an experience that stands out.</p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-bookmark mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Extensive Knowledge Base</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">We're building a comprehensive resource hub to empower players with all the information they need to thrive in our community.<br></p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-cart-full mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Fair &amp; Accessible Perks</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Our perks are thoughtfully priced to offer value without compromising on fairness, ensuring an enjoyable experience for all players.<br></p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div><div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-info mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Strong Branding &amp; Content</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Our branding reflects our commitment to quality and community. While we continue to improve our marketing efforts, our content consistently resonates with our audience.<br></p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div><div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-users mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Selective &amp; Inclusive Community</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Our community fosters a sense of exclusivity while remaining welcoming to players who share our passion for gaming and collaboration.<br></p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div><div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}} item-mb\">\n        <div class=\"item-wrapper\">\n          <div class=\"card-box align-left\">\n            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n              <span mbr-icon class=\"mbr-iconfont mobi-mbri-layers mobi-mbri\"></span>\n            </div>\n            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>Robust Technology Stack</b></h5>\n            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n              We leverage an advanced and diverse tech stack to deliver a seamless and reliable gaming experience.\n            </p>\n\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n              <a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Learn More</a>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
          "_cid": "uVueX3gvzD",
          "_anchor": "features022-1a",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "img": {
              "width": "80px",
              "object-fit": "contain"
            },
            ".image-block": {
              "width": "80px",
              "margin": "auto"
            },
            "& when (@invert)": {
              "img": {
                "filter": "invert(1) brightness(10)"
              }
            },
            ".text": {
              "display": "flex",
              "align-items": "center",
              "@media (max-width: 767px)": {
                "padding-bottom": "2rem"
              }
            }
          },
          "_name": "footer02",
          "_sourceTheme": "offerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"offerm5 footer2\" group=\"Footers\" global once=\"footer\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" value=\"5\" step=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" value=\"5\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"range\" inline title=\"Images\" name=\"items\" min=\"1\" max=\"3\" value=\"1\" step=\"1\">\n        <input type=\"checkbox\" title=\"Invert Color\" name=\"invert\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/offerm5/components/_images/background4.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#13161f\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/offerm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid' : fullWidth }\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-lg-9 text col-md-8 col-sm-12\" mbr-if=\"showTitle\">\n                <h2 class=\"mbr-fonts-style align-left mbr-white  mbr-section-title\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-section-title\">© Copyright 2025 - All Rights Reserved<br>Alliant Games is a Dusty Hansen Productions LLC Company</h2>\n            </div>\n            <div class=\"col-sm-12 col-md-4 d-flex col-lg-3\">\n                <div class=\"image-block\" mbr-if=\"items > 0\">\n\n                    <img class=\"mbr-temp\" src=\"@PROJECT_PATH@/assets/images/avatar-192x192.webp\" alt=\"Mobirise\">\n\n                </div>\n                <div class=\"image-block\" mbr-if=\"items > 1\">\n\n                    <img class=\"mbr-temp\" src=\"@ADDONS_PATH@/offerm5/components/_images/clients/2.png\" alt=\"Mobirise\">\n\n                </div>\n                <div class=\"image-block\" mbr-if=\"items > 2\">\n\n                    <img class=\"mbr-temp\" src=\"@ADDONS_PATH@/offerm5/components/_images/clients/3.png\" alt=\"Mobirise\">\n\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "v2K1ta64eN",
          "_anchor": "footer02-30",
          "_protectedParams": [],
          "_global": true,
          "_once": "footer",
          "_params": {}
        }
      ]
    },
    "faq.html": {
      "settings": {
        "title": "FAQ",
        "meta_descr": "Frequently asked questions.",
        "header_custom": "",
        "footer_custom": "",
        "html_before": "",
        "order": "7",
        "meta_image": "@PROJECT_PATH@/assets/images/11%2520-%2520wnn1hyt-1024x512.png"
      },
      "components": [
        {
          "_name": "amenu2",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu2 expertm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n    <mbr-parameters>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"8\" step=\"0.1\" value=\"8\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <header>Offcanvas</header>\n        <input type=\"color\" title=\"Offcanvas Color\" name=\"offcanvasColor\" value=\"#13161f\">\n        <input type=\"checkbox\" title=\"Links\" name=\"showContacts\" checked>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showOffcanvasLogo\" checked>\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showOffcanvasBrand\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Button\" name=\"showOffcanvasButtons\">\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <header condition=\"showSocial\">Social</header>\n        <select title=\"Icons Align\" name=\"contentAlign\" condition=\"showSocial\">\n            <option value=\"justify-content-start\" selected>Left</option>\n            <option value=\"justify-content-center\">Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <input type=\"checkbox\" title=\"Social Title\" name=\"showSocialTitle\" checked condition=\"showSocial\">\n        <input type=\"color\" title=\"Social Color\" name=\"socialColor\" value=\"#19c2ec\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG Color 1\" name=\"socialBgColor1\" value=\"#1e2024\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG Color 2\" name=\"socialBgColor2\" value=\"#23272b\" condition=\"showSocial\">\n        <input type=\"checkbox\" name=\"socialShadow\" title=\"Social Shadow\" checked condition=\"showSocial\">\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"socialShadow1\" value=\"#191b1f\" condition=\"socialShadow && showSocial\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"socialShadow2\" value=\"#23272B\" condition=\"socialShadow && showSocial\">\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"6\" step=\"1\" value=\"5\" condition=\"showSocial\">\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#13161f\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#19c2ec\">\n        <input type=\"color\" title=\"Hamburger BG 1\" name=\"hamburgerBg1\" value=\"#054fb9\">\n        <input type=\"color\" title=\"Hamburger BG 2\" name=\"hamburgerBg2\" value=\"#054fb9\">\n        <input type=\"checkbox\" name=\"hamburgerShadow\" title=\"Hamburger Shadow\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"hamburgerColor1\" value=\"#8320d2\" condition=\"hamburgerShadow\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"hamburgerColor2\" value=\"#8320d2\" condition=\"hamburgerShadow\">\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n        <div class=\"container-fluid\">\n            <div class=\"navbar-brand\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"index.html\">\n                        <img src=\"@PROJECT_PATH@/assets/images/mark201600x1600-96x96.webp\" alt=\"Alliant Games\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\">\n                    <a class=\"navbar-caption text-white\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">ExpertM5\n                    </a>\n                </span>\n            </div>\n            <div class=\"offcanvas_box\">\n                <button class=\"btn_offcanvas\" type=\"button\" data-bs-toggle=\"offcanvas\" data-bs-target=\"#offcanvasRight\" aria-controls=\"offcanvasRight\">\n                    <div class=\"hamburger-offcanvas\">\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                    </div>\n                </button>\n                <div class=\"offcanvas offcanvas-end\" tabindex=\"-1\" id=\"offcanvasRight\" aria-labelledby=\"offcanvasRightLabel\">\n\n                    <div class=\"offcanvas-body\">\n                        <div class=\"offcanvas_head\">\n                            <div class=\"offcanvas_head_container\">\n                                <div class=\"navbar-brand\">\n                                <span mbr-if=\"showOffcanvasLogo\" class=\"navbar-logo\">\n                                     <a href=\"index.html\">\n                                        <img src=\"@PROJECT_PATH@/assets/images/mark201600x1600-96x96.webp\" alt=\"Alliant Games\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                                     </a>\n                                </span>\n                                    <span mbr-if=\"showOffcanvasBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-success\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">ALLIANT GAMES</a></span>\n                                </div>\n                                <button type=\"button\" class=\"btn-close text-reset\" data-bs-dismiss=\"offcanvas\" aria-label=\"Close\">\n                                    <div class=\"hamburger-offcanvas\">\n                                        <span></span>\n                                        <span></span>\n                                        <span></span>\n                                        <span></span>\n                                    </div>\n                                </button>\n                            </div>\n                            <p class=\"mbr-text mbr-fonts-style mb-0\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">\n                                Excepteur sint occaecat cupidatat non proident\n                            </p>\n                        </div>\n                        <div class=\"offcanvas_link\" mbr-if=\"showContacts\">\n                            <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-7\"><li class=\"nav-item\">\n                                    <a class=\"nav-link link text-white text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">HOME</a>\n                                </li>\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link link text-white text-primary\" href=\"about.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">ABOUT US</a>\n                                </li>\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link link text-white text-primary\" href=\"https://alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">ALLIANT.GG</a>\n                                </li>\n                                <li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"https://verify.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">VERIFY</a></li><li class=\"nav-item dropdown\">\n                                    <a class=\"nav-link link text-white dropdown-toggle\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"false\">SHOP</a><div class=\"dropdown-menu\" aria-labelledby=\"dropdown-655\"><a class=\"text-white dropdown-item text-primary\" href=\"https://perks.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">PERKS SHOP</a><a class=\"text-white dropdown-item text-primary\" href=\"donate.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">DONATE</a></div>\n                                </li>\n                                <li class=\"nav-item dropdown open\"><a class=\"nav-link link text-white dropdown-toggle show\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"true\">HELP</a><div class=\"dropdown-menu show\" aria-labelledby=\"dropdown-330\" data-bs-popper=\"none\"><a class=\"text-white dropdown-item text-primary\" href=\"https://docs.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">HELP CENTER</a><a class=\"text-white dropdown-item text-primary\" href=\"https://status.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">STATUS PAGE</a><a class=\"text-white dropdown-item text-primary\" href=\"faq.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">FAQS</a><a class=\"text-white dropdown-item text-primary\" href=\"privacy.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">PRIVACY POLICY</a><a class=\"text-white dropdown-item text-primary\" href=\"tos.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">TERMS OF SERVICE</a></div></li></ul>\n                        </div>\n                        <div class=\"social-container\" mbr-if=\"showSocial\">\n                            <p class=\"social-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSocialTitle\" data-app-selector=\".social-title\">\n                                FOLLOW US</p>\n                            <div class=\"social-list {{contentAlign}}\">\n                                <div class=\"soc-item\" mbr-if=\"socialCount>0\">\n                                    <a href=\"https://discord.gg/alliant\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-discord socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                                    <a href=\"https://x.com/alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-twitter socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                                    <a href=\"https://instagram.com/alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-instagram socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                                    <a href=\"https://youtube.com/@alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-youtube socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>4\">\n                                    <a href=\"https://tiktok.com/@alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-tiktok socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>5\">\n                                    <span mbr-icon class=\"socicon-vimeo socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"offcanvas_btn\" mbr-if=\"showOffcanvasButtons\">\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-buttons mbr-section-btn custom-section-btn\">\n                                <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    PURCHASE NOW</a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_styles": {
            "& when not (@sticky)": {},
            "& when (@sticky)": {
              "z-index": "1000",
              "width": "100%"
            },
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
              "top": "0.5rem",
              "margin-right": "0.5rem",
              "line-height": "1",
              "font-size": "inherit",
              "vertical-align": "middle",
              "text-align": "center",
              "overflow": "hidden",
              "transform": "scale(0, 1)",
              "transition": "all 0.25s ease-in-out"
            },
            ".dropdown-menu": {
              "padding": "0"
            },
            ".dropdown-item": {
              "padding": "5px 0.4em 5px  0.4em !important",
              "width": "100%",
              "line-height": "inherit !important",
              "transition": "background-position 0.3s ease",
              "@media (max-width: 991px)": {
                "text-align": "left !important"
              },
              "&:hover": {
                "background-position": "right !important",
                "&:after": {
                  "color": "@primaryColor"
                }
              }
            },
            ".nav-dropdown .link": {
              "padding": "0 0.3em !important",
              "margin": "0.667em 1em !important"
            },
            ".nav-dropdown .link.dropdown-toggle::after": {
              "margin-left": "0.5rem",
              "margin-top": "0.2rem"
            },
            ".nav-link": {
              "position": "relative"
            },
            ".container": {
              "display": "flex",
              "margin": "auto",
              "flex-wrap": "wrap"
            },
            ".dropdown-menu, .navbar.opened": {
              "background": "@menuBgColor !important"
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "transition": "all 0.25s ease-in-out",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-right": "0.5rem",
                "vertical-align": "sub",
                "&:before": {
                  "display": "inline-block",
                  "transform": "scale(1, 1)",
                  "transition": "all 0.25s ease-in-out"
                }
              }
            },
            ".navbar": {
              "min-height": "122px",
              "transition": "all 0.3s",
              "&.opened": {
                "transition": "all 0.3s"
              },
              ".dropdown-item": {
                "padding": "0.5rem 1.8rem"
              },
              ".navbar-logo img": {
                "width": "auto"
              },
              ".navbar-collapse": {
                "justify-content": "flex-end",
                "z-index": "1"
              },
              "@media (max-width: 991px)": {
                ".nav-item .nav-link::before": {
                  "display": "none"
                },
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  }
                },
                ".dropdown-menu": {
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]:after": {
                    "margin-left": "0.5rem",
                    "margin-top": "0.2rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
                    "border-left": "0.35em solid transparent",
                    "border-bottom": "0",
                    "top": "40%"
                  }
                },
                ".navbar-logo": {
                  "img": {
                    "height": "3rem !important"
                  }
                },
                "ul.navbar-nav": {
                  "li": {
                    "margin": "auto"
                  }
                },
                ".dropdown-menu .dropdown-item": {
                  "padding": "0.25rem 1.5rem !important",
                  "text-align": "center"
                },
                ".navbar-brand": {
                  "flex-shrink": "initial",
                  "flex-basis": "auto",
                  "word-break": "break-word",
                  "padding-right": "2rem"
                },
                ".navbar-toggler": {
                  "flex-basis": "auto"
                },
                ".icons-menu": {
                  "padding-left": "0",
                  "padding-right": "0",
                  "padding-top": "0.5rem",
                  "padding-bottom": "0.5rem"
                }
              },
              "padding": "0 !important",
              "box-shadow": "none !important",
              "@media (max-width: 575px)": {
                "min-height": "80px"
              },
              "&:not(.navbar-short)": {
                "border-bottom": "none"
              },
              "& when (@sticky)": {
                "background": "transparent"
              },
              "& when not (@sticky)": {
                "background": "@menuBgColor",
                "& when (@transparent)": {
                  "background": "rgba(red(@menuBgColor), green(@menuBgColor), blue(@menuBgColor), @opacity)"
                }
              }
            },
            ".navbar-brand": {
              "min-height": "80px",
              "flex-shrink": "0",
              "align-items": "center",
              "margin-right": "0",
              "transition": "all 0.3s",
              "word-break": "break-word",
              "z-index": "1",
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none"
              },
              "padding-right": "15px",
              "padding-left": "15px",
              "@media (max-width: 575px)": {
                "min-height": "69px"
              }
            },
            ".dropdown-item.active, .dropdown-item:active": {
              "background-color": "transparent"
            },
            ".navbar-expand-lg .navbar-nav .nav-link": {
              "padding": "0"
            },
            ".nav-dropdown .link.dropdown-toggle": {
              "margin-right": "1.667em",
              "&[aria-expanded=\"true\"]": {
                "margin-right": "0",
                "padding": "0.667em 1.667em"
              }
            },
            ".navbar.navbar-expand-lg .dropdown": {
              ".dropdown-menu": {
                "background": "@menuBgColor",
                ".dropdown-submenu": {
                  "margin": "0",
                  "left": "100%"
                }
              }
            },
            ".navbar .dropdown.open > .dropdown-menu": {
              "display": "block"
            },
            "ul.navbar-nav": {
              "flex-wrap": "wrap"
            },
            "button.navbar-toggler": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "50px",
              "height": "50px",
              "border-radius": "50%",
              "margin-right": "15px",
              "transition": "all 0.3s",
              "background": "linear-gradient(145deg, @hamburgerBg1, @hamburgerBg2)",
              "& when (@hamburgerShadow)": {
                "box-shadow": "10px 10px 19px @hamburgerColor1, -10px -10px 19px @hamburgerColor2"
              },
              "outline": "none",
              "cursor": "pointer",
              "position": "relative",
              "align-self": "center",
              "&:hover": {
                "transform": "scale(1.1)"
              },
              ".hamburger": {
                "position": "relative",
                "width": "23px",
                "height": "24px",
                "transition": "all 0.3s"
              },
              ".hamburger span": {
                "position": "absolute",
                "right": "2px",
                "width": "20px",
                "height": "2px",
                "background-color": "@hamburgerColor",
                "&:nth-child(1)": {
                  "top": "6px",
                  "transition": "all 0.2s"
                },
                "&:nth-child(2)": {
                  "top": "11px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(3)": {
                  "top": "11px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "transition": "all 0.2s"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "6px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              },
              "&:nth-child(2)": {
                "transform": "rotate(45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(3)": {
                "transform": "rotate(-45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(4)": {
                "top": "6px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              }
            },
            ".navbar-dropdown": {
              "padding": "0",
              "& when (@sticky)": {
                "position": "fixed"
              }
            },
            "a.nav-link": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center"
            },
            ".icons-menu": {
              "flex-wrap": "nowrap",
              "display": "flex",
              "justify-content": "center",
              "padding-left": "1rem",
              "padding-right": "1rem",
              "padding-top": "0.3rem",
              "text-align": "center"
            },
            "@media screen and (~'-ms-high-contrast: active'), (~'-ms-high-contrast: none')": {
              ".navbar": {
                "height": "70px",
                "&.opened": {
                  "height": "auto"
                }
              },
              ".nav-item .nav-link:hover::before": {
                "width": "175%",
                "max-width": "calc(100% ~\"+\" 2rem)",
                "left": "-1rem"
              }
            },
            ".navbar-short": {
              "min-height": "90px",
              "border-bottom": "1px solid rgba(255, 255, 255, 0.1) !important",
              "background": "@menuBgColor",
              "& when (@transparent)": {
                "background": "rgba(red(@menuBgColor), green(@menuBgColor), blue(@menuBgColor), @opacity)"
              },
              "@media (max-width: 575px)": {
                "min-height": "70px"
              }
            },
            ".container-fluid": {
              "flex-wrap": "nowrap",
              "padding": "0 64px",
              "@media (max-width: 1599px)": {
                "padding": "0 30px"
              },
              "@media (max-width: 767px)": {
                "padding": "0 20px"
              },
              "@media (max-width: 575px)": {
                "padding": "0 3px"
              }
            },
            ".navbar-collapse": {
              "padding-left": "15px",
              "padding-right": "15px"
            },
            ".navbar-nav": {
              ".nav-item": {
                "margin": "0 !important",
                ".nav-link": {
                  "margin": "0 !important",
                  "padding": "10px 0 !important",
                  "transition": "0.3s all",
                  "opacity": "1",
                  "&:hover": {
                    "opacity": "1",
                    "color": "#FFFFFF !important"
                  },
                  "justify-content": "flex-start",
                  "&:hover, &:focus, &:active": {
                    "opacity": "1",
                    "color": "#FFFFFF !important"
                  }
                },
                "width": "100%",
                "text-align": "left",
                ".dropdown-menu": {
                  "position": "static !important",
                  "background-color": "@offcanvasColor !important"
                }
              },
              "display": "flex !important"
            },
            ".mbr-section-btn": {
              ".btn": {
                "padding": "15px 35px"
              }
            },
            "@media (min-width: 992px)": {
              ".container-fluid": {
                "flex-wrap": "nowrap"
              },
              ".dropdown:hover > .nav-link.dropdown-toggle::after, .dropdown:hover > .link.dropdown-toggle::after, .dropdown:focus-within > .nav-link.dropdown-toggle::after, .dropdown:focus-within > .link.dropdown-toggle::after": {
                "content": "\"−\"",
                "color": "@primaryColor"
              }
            },
            "button.btn_offcanvas": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "50px",
              "height": "50px",
              "border-radius": "50%",
              "margin-right": "15px",
              "transition": "all 0.3s",
              "background": "linear-gradient(145deg, @hamburgerBg1, @hamburgerBg2)",
              "& when (@hamburgerShadow)": {
                "box-shadow": "10px 10px 19px @hamburgerColor1, -10px -10px 19px @hamburgerColor1"
              },
              "outline": "none",
              "border": "none",
              "cursor": "pointer",
              "position": "relative",
              "align-self": "center",
              "&:hover": {
                "transform": "scale(1.1)"
              },
              ".hamburger-offcanvas": {
                "position": "relative",
                "width": "23px",
                "height": "24px",
                "transition": "all 0.3s"
              },
              ".hamburger-offcanvas span": {
                "position": "absolute",
                "right": "2px",
                "width": "20px",
                "height": "2px",
                "background-color": "@hamburgerColor",
                "&:nth-child(1)": {
                  "top": "6px",
                  "transition": "all 0.2s"
                },
                "&:nth-child(2)": {
                  "top": "11px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(3)": {
                  "top": "11px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "transition": "all 0.2s"
                }
              }
            },
            ".btn-close": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "50px",
              "height": "50px",
              "border-radius": "50%",
              "margin-left": "15px",
              "transition": "all 0.3s",
              "opacity": "1 !important",
              "background": "linear-gradient(145deg, @hamburgerBg1, @hamburgerBg2)",
              "& when (@hamburgerShadow)": {
                "box-shadow": "10px 10px 19px @hamburgerColor1, -10px -10px 19px @hamburgerColor2"
              },
              "outline": "none",
              "border": "none",
              "cursor": "pointer",
              "position": "relative",
              "align-self": "center",
              "&:hover": {
                "transform": "scale(1.1)",
                "opacity": "1 !important"
              },
              ".hamburger-offcanvas": {
                "position": "relative",
                "width": "23px",
                "height": "24px",
                "transition": "all 0.3s"
              },
              ".hamburger-offcanvas span": {
                "position": "absolute",
                "right": "2px",
                "width": "20px",
                "height": "2px",
                "background-color": "@hamburgerColor",
                "&:nth-child(1)": {
                  "display": "none"
                },
                "&:nth-child(2)": {
                  "top": "11px",
                  "transform": "rotate(45deg)",
                  "transition": "all 0.25s"
                },
                "&:nth-child(3)": {
                  "top": "11px",
                  "transform": "rotate(-45deg)",
                  "transition": "all 0.25s"
                },
                "&:nth-child(4)": {
                  "display": "none"
                }
              }
            },
            ".offcanvas-end": {
              "left": "0 !important",
              "transform": "translateX(-100%)"
            },
            ".offcanvas.show": {
              "transform": "translateX(0)"
            },
            ".offcanvas": {
              "padding": "0",
              "width": "100%",
              "border-left": "none !important",
              "background-color": "transparent !important",
              "transition": "transform 0.5s ease-in-out"
            },
            ".offcanvas_box": {
              "display": "flex",
              "justify-content": "center",
              "align-items": "center"
            },
            ".offcanvas-body": {
              "display": "flex",
              "flex-direction": "column",
              "align-items": "stretch",
              "padding": "25px",
              "width": "375px",
              "margin-right": "auto",
              "text-align": "left",
              "background-color": "@offcanvasColor",
              "box-shadow": "0 0 10px 0 rgba(0, 0, 0, 0.7)",
              "@media (max-width: 575px)": {
                "width": "260px",
                "padding": "10px"
              },
              ".offcanvas_head": {
                "width": "100%",
                "border-bottom": "1px solid rgba(255, 255, 255, 0.1)",
                "padding-bottom": "20px"
              },
              ".offcanvas_head_container": {
                "display": "flex",
                "align-items": "center",
                "justify-content": "space-between"
              },
              ".navbar-brand": {
                "min-height": "70px",
                "padding": "0 !important",
                ".navbar-logo": {
                  "@media (max-width: 575px)": {
                    "margin-right": "0.5rem"
                  }
                },
                "img": {
                  "height": "70px !important",
                  "@media (max-width: 575px)": {
                    "height": "60px !important"
                  }
                }
              }
            },
            ".mbr-text": {
              "color": "#878e99",
              "margin-top": "20px",
              "padding-right": "7%"
            },
            ".modal-backdrop.show": {
              "opacity": "0.8"
            },
            ".offcanvas_link": {
              "width": "100%",
              "overflow": "auto",
              "padding": "0",
              "margin-top": "20px"
            },
            "::-webkit-scrollbar": {
              "width": "1em"
            },
            "::-webkit-scrollbar-track": {
              "background-color": "#232323"
            },
            "::-webkit-scrollbar-thumb": {
              "background-color": "#535B6D",
              "border-radius": "1em"
            },
            ".social-container": {
              "width": "100%",
              "margin-top": "auto",
              "@media (max-width: 991px)": {
                "padding-top": "40px"
              }
            },
            ".social-title": {
              "color": "#C4CFDE",
              "border-top": "1px solid rgba(255, 255, 255, 0.1)",
              "padding-top": "20px",
              "margin-top": "50px !important"
            },
            ".social-list": {
              "display": "flex",
              "align-items": "center",
              "flex-wrap": "wrap",
              "margin": "-7px"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "position": "relative",
              "margin": "7px",
              "min-width": "53px",
              "padding": "10px",
              "aspect-ratio": "(1 / 1)",
              "border-radius": "6px",
              "background": "linear-gradient(145deg, @socialBgColor1, @socialBgColor2)",
              "& when (@socialShadow)": {
                "box-shadow": "10px 10px 19px @socialShadow1, -10px -10px 19px @socialShadow2"
              },
              "transition": "0.4s all",
              "&:before": {
                "content": "\"\"",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "z-index": "4",
                "transition": "0.4s all",
                "width": "100%",
                "height": "100%",
                "border-radius": "5px",
                "background": "linear-gradient(to right bottom, #212428, #16181c)",
                "opacity": "0"
              },
              ".mbr-iconfont": {
                "position": "relative",
                "z-index": "5",
                "transition": "0.4s all",
                "font-size": "20px",
                "color": "@socialColor"
              },
              "&:hover": {
                "transform": "translateY(-3px)",
                "&:before": {
                  "opacity": "1"
                }
              },
              "a": {
                "animation": "none"
              }
            },
            ".offcanvas_btn": {
              "margin-top": "auto",
              ".mbr-section-btn": {
                "display": "flex",
                "flex-direction": "column",
                "align-items": "stretch",
                "width": "100%",
                "margin-left": "-0.6rem",
                "margin-right": "-0.6rem",
                ".btn": {
                  "flex-grow": "1"
                }
              }
            },
            ".nav-dropdown .link.dropdown-toggle::after, .dropdown-toggle[data-toggle=\"dropdown-submenu\"]::after": {
              "content": "\"+\"",
              "border": "none !important",
              "display": "inline-block",
              "margin-left": ".5rem",
              "margin-top": "0",
              "position": "static",
              "line-height": "1",
              "font-weight": "700",
              "color": "currentColor",
              "transform": "none"
            },
            "@media (max-width: 991px)": {
              ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]::after": {
                "content": "\"+\"",
                "border": "none !important"
              }
            }
          },
          "_cid": "uUaEIHnzfs",
          "_anchor": "amenu2-z",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0",
                "@media (max-width: 992px)": {
                  "padding": "0"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 16px"
              }
            },
            ".row": {
              "justify-content": "center",
              "margin": "0 20px",
              "@media (max-width: 992px)": {
                "margin": "0 10px"
              },
              ".item": {
                "padding": "0"
              }
            },
            ".title-wrapper": {
              "margin-bottom": "40px",
              "@media (max-width: 992px)": {
                "margin-bottom": "20px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              }
            },
            ".panel-group": {
              "border": "1px solid @container",
              "border-radius": "20px",
              "overflow": "hidden",
              ".card": {
                "border-top": "1px solid @border",
                "border-radius": "0 !important",
                "&:first-child": {
                  "border-top": "none"
                },
                "&:last-child": {
                  "border-bottom": "none"
                },
                ".card-header": {
                  "padding": "0",
                  "border": "none",
                  "background-color": "transparent",
                  ".panel-title": {
                    "padding": "30px",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "space-between",
                    "transition": "all 0.3s ease-in-out",
                    "@media (max-width: 992px)": {
                      "padding": "20px 10px"
                    },
                    "&:not(.collapsed)": {
                      "background-color": "@active",
                      ".mbr-iconfont": {
                        "transform": "rotate(-180deg)",
                        "color": "@iconBg",
                        "background-color": "@icon"
                      },
                      ".panel-title-edit": {
                        "color": "@icon"
                      }
                    },
                    ".panel-title-edit": {
                      "margin-bottom": "0",
                      "transition": "all 0.3s ease-in-out"
                    },
                    ".mbr-iconfont": {
                      "display": "flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "width": "60px",
                      "min-width": "60px",
                      "height": "60px",
                      "border-radius": "50%",
                      "font-size": "30px",
                      "color": "@icon",
                      "background-color": "@iconBg",
                      "margin-left": "10px",
                      "transition": "all 0.3s ease-in-out"
                    }
                  }
                },
                ".panel-collapse": {
                  ".panel-body": {
                    "padding": "30px",
                    "@media (max-width: 992px)": {
                      "padding": "20px 10px"
                    },
                    ".panel-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".image-wrapper": {
              "height": "100%",
              "img": {
                "height": "100%",
                "object-fit": "cover",
                "@media (max-width: 992px)": {
                  "height": "350px"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#dfcefd",
              "text-align": "center"
            },
            ".panel-title-edit": {
              "color": "#fdfcfc"
            },
            ".panel-text": {
              "color": "#fdfcfc"
            }
          },
          "_name": "list02",
          "_sourceTheme": "planm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list02 planm5\" group=\"List\" plugins=\"mbr-switch-arrow, mobirise-icons\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"10\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Cards</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <input type=\"color\" title=\"Icon Color\" value=\"#192227\" name=\"icon\" selected>\n        <input type=\"color\" title=\"Icon BG\" value=\"#8320d2\" name=\"iconBg\" selected>\n        <input type=\"color\" title=\"Active Bg\" value=\"#19c2ec\" name=\"active\" selected>\n        <input type=\"color\" title=\"Border Card\" value=\"#4a5357\" name=\"border\" selected>\n        <input type=\"color\" title=\"Border Container\" value=\"#f7f7f7\" name=\"container\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/planm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#13161f\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/planm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 col-lg-10 item\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">\n                        FAQ\n                    </h2>\n                </div>\n                <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                    <div class=\"card\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">I NEED ASSISTANCE FROM THE ALLIANT GAMES STAFF, WHERE DO I GO?</h4>\n                                <span class=\"sign mbr-iconfont mobi-mbri-down mobi-mbri\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    There are several ways to get help: Open a ticket in our Discord, use the chat widget on our website, or email us at support@alliant.gg\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 1\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">\n                                    \n                                <div><span style=\"font-size: 2rem;\">I'VE BEEN BANNED FROM THE SERVER, HOW DO I REQUEST AN UNBAN?</span><br></div></h4>\n                                <span class=\"sign mbr-iconfont mobi-mbri-down mobi-mbri\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    You can open a ban appeal ticket in our Discord. If you have been banned from the Discord, you can email us at support@alliant.gg or use our chat widget for assistance.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 2\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">I THINK THE SERVER IS DOWN, HOW DO I CONFIRM?</h4>\n                                <span class=\"sign mbr-iconfont mobi-mbri-down mobi-mbri\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Visit our Status Page at https://status.alliant.gg for the latest server status.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">HOW DO I VERIFY MY ACCOUNT?</h4>\n                                <span class=\"sign mbr-iconfont mobi-mbri-down mobi-mbri\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Visit our Verification Page at https://verify.alliant.gg to login with Steam and Discord to verify your accounts.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">WHERE CAN I GET VIP AND PERKS?</h4>\n                                <span class=\"sign mbr-iconfont mobi-mbri-down mobi-mbri\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Visit our Perks Shop at https://perks.alliant.gg to purchase VIP or additional Perks.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 5\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">\n                                    How do you customize financial plans for clients?\n                                </h4>\n                                <span class=\"sign mbr-iconfont mobi-mbri-down mobi-mbri\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    We believe in personalized financial planning. Our advisors will work closely\n                                    with you to understand your financial goals, risk tolerance, and time horizon.\n                                    Based on this information, we'll create a tailored financial plan to help you\n                                    achieve your objectives.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uU8gVEpNR6",
          "_anchor": "list02-q",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "aheader5",
          "_sourceTheme": "ideam5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header4\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"10\" condition=\"fullScreen == false\">\n\n        <input type=\"range\" inline name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value selected>Left</option>\n            <option value=\"justify-content-center\">Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/ideam5/components/_images/background6.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#13161f\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/ideam5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Liner Gradient\" name=\"linerGradient\" condition=\"bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Horizontally \" name=\"horizontallyGradient\" condition=\"bg.type == 'color' && linerGradient\">\n        <input type=\"color\" title=\"Gradient Color\" name=\"gradientColor\" value=\"#6138ff\" condition=\"linerGradient && bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row {{contentAlign}}\">\n            <div class=\"col-12 col-lg-{{textWidth}}\">\n                <h1 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">NEED MORE HELP?<b></b></h1>\n                <p class=\"mbr-text mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-5\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                    Visit our Help Center!\n                </p>\n                <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn align-center\" mbr-if=\"showButtons\"><a class=\"btn btn-primary\" href=\"https://docs.alliant.gg\" data-app-placeholder=\"Type Text\" target=\"_blank\">Help Center</a></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              "& when (@linerGradient)": {
                "background": "linear-gradient(180deg, @bg-value, @gradientColor)",
                "& when (@horizontallyGradient)": {
                  "background": "linear-gradient(90deg, @bg-value, @gradientColor) !important"
                }
              }
            },
            ".container": {
              "max-width": "1040px"
            },
            ".row": {
              "@media (max-width: 575px)": {
                "text-align": "center!important"
              }
            },
            ".mbr-section-title": {
              "color": "#000000",
              "@media (max-width: 575px)": {
                "text-align": "center"
              }
            },
            ".mbr-text": {
              "color": "#8320d2",
              "margin-top": "20px",
              "a": {
                "&:hover": {
                  "text-decoration": "underline"
                }
              }
            },
            ".mbr-section-btn": {
              "margin-top": "20px",
              "& .btn": {
                "border-radius": "50px"
              },
              "@media (max-width: 575px)": {
                "display": "flex",
                "flex-wrap": "wrap",
                "& .btn": {
                  "width": "100%"
                }
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-title, .mbr-section-btn": {
              "color": "#dfcefd"
            }
          },
          "_cid": "uU8knO55O3",
          "_anchor": "aheader5-s",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "img": {
              "width": "80px",
              "object-fit": "contain"
            },
            ".image-block": {
              "width": "80px",
              "margin": "auto"
            },
            "& when (@invert)": {
              "img": {
                "filter": "invert(1) brightness(10)"
              }
            },
            ".text": {
              "display": "flex",
              "align-items": "center",
              "@media (max-width: 767px)": {
                "padding-bottom": "2rem"
              }
            }
          },
          "_name": "footer02",
          "_sourceTheme": "offerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"offerm5 footer2\" group=\"Footers\" global once=\"footer\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" value=\"5\" step=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" value=\"5\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"range\" inline title=\"Images\" name=\"items\" min=\"1\" max=\"3\" value=\"1\" step=\"1\">\n        <input type=\"checkbox\" title=\"Invert Color\" name=\"invert\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/offerm5/components/_images/background4.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#13161f\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/offerm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid' : fullWidth }\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-lg-9 text col-md-8 col-sm-12\" mbr-if=\"showTitle\">\n                <h2 class=\"mbr-fonts-style align-left mbr-white  mbr-section-title\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-section-title\">© Copyright 2025 - All Rights Reserved<br>Alliant Games is a Dusty Hansen Productions LLC Company</h2>\n            </div>\n            <div class=\"col-sm-12 col-md-4 d-flex col-lg-3\">\n                <div class=\"image-block\" mbr-if=\"items > 0\">\n\n                    <img class=\"mbr-temp\" src=\"@PROJECT_PATH@/assets/images/avatar-192x192.webp\" alt=\"Mobirise\">\n\n                </div>\n                <div class=\"image-block\" mbr-if=\"items > 1\">\n\n                    <img class=\"mbr-temp\" src=\"@ADDONS_PATH@/offerm5/components/_images/clients/2.png\" alt=\"Mobirise\">\n\n                </div>\n                <div class=\"image-block\" mbr-if=\"items > 2\">\n\n                    <img class=\"mbr-temp\" src=\"@ADDONS_PATH@/offerm5/components/_images/clients/3.png\" alt=\"Mobirise\">\n\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "v2K1ta64eN",
          "_anchor": "footer02-30",
          "_protectedParams": [],
          "_global": true,
          "_once": "footer",
          "_params": {}
        }
      ]
    },
    "privacy.html": {
      "settings": {
        "title": "Privacy Policy",
        "meta_descr": "Learn more about the information we collect and how we use it.",
        "header_custom": "",
        "footer_custom": "",
        "html_before": "",
        "order": "8",
        "meta_image": "@PROJECT_PATH@/assets/images/11%2520-%2520wnn1hyt-1024x512.png"
      },
      "components": [
        {
          "_name": "amenu2",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu2 expertm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n    <mbr-parameters>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"8\" step=\"0.1\" value=\"8\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <header>Offcanvas</header>\n        <input type=\"color\" title=\"Offcanvas Color\" name=\"offcanvasColor\" value=\"#13161f\">\n        <input type=\"checkbox\" title=\"Links\" name=\"showContacts\" checked>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showOffcanvasLogo\" checked>\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showOffcanvasBrand\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Button\" name=\"showOffcanvasButtons\">\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <header condition=\"showSocial\">Social</header>\n        <select title=\"Icons Align\" name=\"contentAlign\" condition=\"showSocial\">\n            <option value=\"justify-content-start\" selected>Left</option>\n            <option value=\"justify-content-center\">Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <input type=\"checkbox\" title=\"Social Title\" name=\"showSocialTitle\" checked condition=\"showSocial\">\n        <input type=\"color\" title=\"Social Color\" name=\"socialColor\" value=\"#19c2ec\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG Color 1\" name=\"socialBgColor1\" value=\"#1e2024\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG Color 2\" name=\"socialBgColor2\" value=\"#23272b\" condition=\"showSocial\">\n        <input type=\"checkbox\" name=\"socialShadow\" title=\"Social Shadow\" checked condition=\"showSocial\">\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"socialShadow1\" value=\"#191b1f\" condition=\"socialShadow && showSocial\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"socialShadow2\" value=\"#23272B\" condition=\"socialShadow && showSocial\">\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"6\" step=\"1\" value=\"5\" condition=\"showSocial\">\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#13161f\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#19c2ec\">\n        <input type=\"color\" title=\"Hamburger BG 1\" name=\"hamburgerBg1\" value=\"#054fb9\">\n        <input type=\"color\" title=\"Hamburger BG 2\" name=\"hamburgerBg2\" value=\"#054fb9\">\n        <input type=\"checkbox\" name=\"hamburgerShadow\" title=\"Hamburger Shadow\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"hamburgerColor1\" value=\"#8320d2\" condition=\"hamburgerShadow\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"hamburgerColor2\" value=\"#8320d2\" condition=\"hamburgerShadow\">\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n        <div class=\"container-fluid\">\n            <div class=\"navbar-brand\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"index.html\">\n                        <img src=\"@PROJECT_PATH@/assets/images/mark201600x1600-96x96.webp\" alt=\"Alliant Games\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\">\n                    <a class=\"navbar-caption text-white\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">ExpertM5\n                    </a>\n                </span>\n            </div>\n            <div class=\"offcanvas_box\">\n                <button class=\"btn_offcanvas\" type=\"button\" data-bs-toggle=\"offcanvas\" data-bs-target=\"#offcanvasRight\" aria-controls=\"offcanvasRight\">\n                    <div class=\"hamburger-offcanvas\">\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                    </div>\n                </button>\n                <div class=\"offcanvas offcanvas-end\" tabindex=\"-1\" id=\"offcanvasRight\" aria-labelledby=\"offcanvasRightLabel\">\n\n                    <div class=\"offcanvas-body\">\n                        <div class=\"offcanvas_head\">\n                            <div class=\"offcanvas_head_container\">\n                                <div class=\"navbar-brand\">\n                                <span mbr-if=\"showOffcanvasLogo\" class=\"navbar-logo\">\n                                     <a href=\"index.html\">\n                                        <img src=\"@PROJECT_PATH@/assets/images/mark201600x1600-96x96.webp\" alt=\"Alliant Games\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                                     </a>\n                                </span>\n                                    <span mbr-if=\"showOffcanvasBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-success\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">ALLIANT GAMES</a></span>\n                                </div>\n                                <button type=\"button\" class=\"btn-close text-reset\" data-bs-dismiss=\"offcanvas\" aria-label=\"Close\">\n                                    <div class=\"hamburger-offcanvas\">\n                                        <span></span>\n                                        <span></span>\n                                        <span></span>\n                                        <span></span>\n                                    </div>\n                                </button>\n                            </div>\n                            <p class=\"mbr-text mbr-fonts-style mb-0\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">\n                                Excepteur sint occaecat cupidatat non proident\n                            </p>\n                        </div>\n                        <div class=\"offcanvas_link\" mbr-if=\"showContacts\">\n                            <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-7\"><li class=\"nav-item\">\n                                    <a class=\"nav-link link text-white text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">HOME</a>\n                                </li>\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link link text-white text-primary\" href=\"about.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">ABOUT US</a>\n                                </li>\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link link text-white text-primary\" href=\"https://alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">ALLIANT.GG</a>\n                                </li>\n                                <li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"https://verify.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">VERIFY</a></li><li class=\"nav-item dropdown\">\n                                    <a class=\"nav-link link text-white dropdown-toggle\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"false\">SHOP</a><div class=\"dropdown-menu\" aria-labelledby=\"dropdown-655\"><a class=\"text-white dropdown-item text-primary\" href=\"https://perks.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">PERKS SHOP</a><a class=\"text-white dropdown-item text-primary\" href=\"donate.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">DONATE</a></div>\n                                </li>\n                                <li class=\"nav-item dropdown open\"><a class=\"nav-link link text-white dropdown-toggle show\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"true\">HELP</a><div class=\"dropdown-menu show\" aria-labelledby=\"dropdown-330\" data-bs-popper=\"none\"><a class=\"text-white dropdown-item text-primary\" href=\"https://docs.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">HELP CENTER</a><a class=\"text-white dropdown-item text-primary\" href=\"https://status.alliant.gg\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">STATUS PAGE</a><a class=\"text-white dropdown-item text-primary\" href=\"faq.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">FAQS</a><a class=\"text-white dropdown-item text-primary\" href=\"privacy.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">PRIVACY POLICY</a><a class=\"text-white dropdown-item text-primary\" href=\"tos.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">TERMS OF SERVICE</a></div></li></ul>\n                        </div>\n                        <div class=\"social-container\" mbr-if=\"showSocial\">\n                            <p class=\"social-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSocialTitle\" data-app-selector=\".social-title\">\n                                FOLLOW US</p>\n                            <div class=\"social-list {{contentAlign}}\">\n                                <div class=\"soc-item\" mbr-if=\"socialCount>0\">\n                                    <a href=\"https://discord.gg/alliant\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-discord socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                                    <a href=\"https://x.com/alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-twitter socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                                    <a href=\"https://instagram.com/alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-instagram socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                                    <a href=\"https://youtube.com/@alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-youtube socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>4\">\n                                    <a href=\"https://tiktok.com/@alliantgames\" target=\"_blank\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-tiktok socicon\"></span></a>\n                                </div>\n                                <div class=\"soc-item\" mbr-if=\"socialCount>5\">\n                                    <span mbr-icon class=\"socicon-vimeo socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"offcanvas_btn\" mbr-if=\"showOffcanvasButtons\">\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-buttons mbr-section-btn custom-section-btn\">\n                                <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    PURCHASE NOW</a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_styles": {
            "& when not (@sticky)": {},
            "& when (@sticky)": {
              "z-index": "1000",
              "width": "100%"
            },
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
              "top": "0.5rem",
              "margin-right": "0.5rem",
              "line-height": "1",
              "font-size": "inherit",
              "vertical-align": "middle",
              "text-align": "center",
              "overflow": "hidden",
              "transform": "scale(0, 1)",
              "transition": "all 0.25s ease-in-out"
            },
            ".dropdown-menu": {
              "padding": "0"
            },
            ".dropdown-item": {
              "padding": "5px 0.4em 5px  0.4em !important",
              "width": "100%",
              "line-height": "inherit !important",
              "transition": "background-position 0.3s ease",
              "@media (max-width: 991px)": {
                "text-align": "left !important"
              },
              "&:hover": {
                "background-position": "right !important",
                "&:after": {
                  "color": "@primaryColor"
                }
              }
            },
            ".nav-dropdown .link": {
              "padding": "0 0.3em !important",
              "margin": "0.667em 1em !important"
            },
            ".nav-dropdown .link.dropdown-toggle::after": {
              "margin-left": "0.5rem",
              "margin-top": "0.2rem"
            },
            ".nav-link": {
              "position": "relative"
            },
            ".container": {
              "display": "flex",
              "margin": "auto",
              "flex-wrap": "wrap"
            },
            ".dropdown-menu, .navbar.opened": {
              "background": "@menuBgColor !important"
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "transition": "all 0.25s ease-in-out",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-right": "0.5rem",
                "vertical-align": "sub",
                "&:before": {
                  "display": "inline-block",
                  "transform": "scale(1, 1)",
                  "transition": "all 0.25s ease-in-out"
                }
              }
            },
            ".navbar": {
              "min-height": "122px",
              "transition": "all 0.3s",
              "&.opened": {
                "transition": "all 0.3s"
              },
              ".dropdown-item": {
                "padding": "0.5rem 1.8rem"
              },
              ".navbar-logo img": {
                "width": "auto"
              },
              ".navbar-collapse": {
                "justify-content": "flex-end",
                "z-index": "1"
              },
              "@media (max-width: 991px)": {
                ".nav-item .nav-link::before": {
                  "display": "none"
                },
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  }
                },
                ".dropdown-menu": {
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]:after": {
                    "margin-left": "0.5rem",
                    "margin-top": "0.2rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
                    "border-left": "0.35em solid transparent",
                    "border-bottom": "0",
                    "top": "40%"
                  }
                },
                ".navbar-logo": {
                  "img": {
                    "height": "3rem !important"
                  }
                },
                "ul.navbar-nav": {
                  "li": {
                    "margin": "auto"
                  }
                },
                ".dropdown-menu .dropdown-item": {
                  "padding": "0.25rem 1.5rem !important",
                  "text-align": "center"
                },
                ".navbar-brand": {
                  "flex-shrink": "initial",
                  "flex-basis": "auto",
                  "word-break": "break-word",
