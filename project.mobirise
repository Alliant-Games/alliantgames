              ".dropdown:hover > .nav-link.dropdown-toggle::after, .dropdown:hover > .link.dropdown-toggle::after, .dropdown:focus-within > .nav-link.dropdown-toggle::after, .dropdown:focus-within > .link.dropdown-toggle::after": {
