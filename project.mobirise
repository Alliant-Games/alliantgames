            },
            "::-webkit-scrollbar-thumb": {
              "background-color": "#535B6D",
              "border-radius": "1em"
            },
            ".social-container": {
              "width": "100%",
              "margin-top": "auto",
              "@media (max-width: 991px)": {
                "padding-top": "40px"
              }
            },
            ".social-title": {
              "color": "#C4CFDE",
              "border-top": "1px solid rgba(255, 255, 255, 0.1)",
