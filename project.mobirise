              "line-height": "1",
              "font-weight": "700",
              "color": "currentColor",
              "transform": "none"
            },
            "@media (max-width: 991px)": {
              ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]::after": {
                "content": "\"+\"",
                "border": "none !important"
              }
            }
